@{
    Layout = null; // Layout dosyası olmadığı için null yapıp kütüphaneleri aşağıda ekledik
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kontrol Paneli | EasyRent</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">

    <style>
        body {
            background-color: #f4f6f9;
            font-family: 'Segoe UI', sans-serif;
        }

        .nav-pills .nav-link {
            background: white;
            color: #6c757d;
            border: 1px solid #e9ecef;
            margin: 0 5px;
            border-radius: 50px;
            transition: 0.3s;
        }

            .nav-pills .nav-link.active {
                background: #0d6efd;
                color: white;
                box-shadow: 0 5px 15px rgba(13, 110, 253, 0.3);
                border-color: transparent;
            }

        .hover-card:hover {
            transform: translateY(-5px);
            transition: 0.3s;
        }

        .w-35 {
            width: 35%;
        }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg bg-white shadow-sm mb-4">
        <div class="container">
            <a class="navbar-brand fw-bold text-primary" href="/Home/Index"><i class="fas fa-car me-2"></i>EasyRent</a>
            <div class="d-flex align-items-center">
                <span class="me-3 fw-bold text-dark d-none d-md-block">Ayşe Demir</span>
                <a href="/Account/Logout" class="btn btn-outline-danger btn-sm rounded-pill"><i class="fas fa-sign-out-alt me-1"></i>Çıkış</a>
            </div>
        </div>
    </nav>

    <div class="container pb-5">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h3 class="fw-bold text-dark m-0">Hoş Geldin, Ayşe 👋</h3>
                <p class="text-muted small m-0">Bugün araç kiralamak için harika bir gün!</p>
            </div>
            <button class="btn btn-primary rounded-pill px-4 shadow-sm" data-bs-toggle="modal" data-bs-target="#filterModal">
                <i class="fas fa-search me-2"></i>Hızlı Araç Bul
            </button>
        </div>

        <ul class="nav nav-pills nav-justified mb-4" id="pills-tab" role="tablist">
            <li class="nav-item">
                <button class="nav-link active fw-bold py-3" data-bs-toggle="pill" data-bs-target="#tab-aktif">
                    <i class="fas fa-key me-2"></i>Aktif Kiralamam
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link fw-bold py-3" data-bs-toggle="pill" data-bs-target="#tab-favori">
                    <i class="fas fa-heart me-2"></i>Favoriler & Kıyaslama
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link fw-bold py-3" data-bs-toggle="pill" data-bs-target="#tab-gecmis">
                    <i class="fas fa-history me-2"></i>Son Gezilenler
                </button>
            </li>
        </ul>

        <div class="tab-content" id="pills-tabContent">

            <div class="tab-pane fade show active" id="tab-aktif">
                @if (ViewBag.AktifKiralamaVarMi)
                {
                    <div class="card border-0 shadow-sm rounded-4 overflow-hidden bg-white">
                        <div class="row g-0">
                            <div class="col-md-6 bg-light d-flex align-items-center justify-content-center p-4">
                                <img src="@ViewBag.AktifArac.Resim" class="img-fluid rounded shadow-sm" alt="Arac" style="max-height:300px;">
                            </div>
                            <div class="col-md-6 p-4 d-flex flex-column justify-content-center">
                                <div class="badge bg-success w-25 mb-3">KİRADA</div>
                                <h2 class="fw-bold">@ViewBag.AktifArac.Marka @ViewBag.AktifArac.Model</h2>
                                <h5 class="text-muted mb-4"><i class="fas fa-hashtag me-2"></i>@ViewBag.AktifArac.Plaka</h5>

                                <div class="row g-3 mb-4">
                                    <div class="col-6">
                                        <div class="border p-3 rounded text-center">
                                            <small class="text-muted fw-bold">İADE TARİHİ</small>
                                            <div class="fs-5 fw-bold text-dark">@ViewBag.AktifArac.TeslimTarihi</div>
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <div class="border p-3 rounded text-center bg-danger bg-opacity-10 border-danger">
                                            <small class="text-danger fw-bold">KALAN GÜN</small>
                                            <div class="fs-5 fw-bold text-danger">@ViewBag.AktifArac.KalanGun Gün</div>
                                        </div>
                                    </div>
                                </div>
                                <button class="btn btn-outline-dark w-100 rounded-pill"><i class="fas fa-tools me-2"></i>Hasar/Sorun Bildir</button>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="alert alert-info text-center p-5 rounded-4">Aktif kiralama bulunamadı.</div>
                }
            </div>

            <div class="tab-pane fade" id="tab-favori">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="fw-bold text-dark">Favori Araçlarım</h5>
                    <button class="btn btn-secondary rounded-pill px-4" id="btnCompare" onclick="compareSelected()" disabled>
                        <i class="fas fa-balance-scale me-2"></i>Seçilenleri Kıyasla (<span id="countSpan">0</span>/2)
                    </button>
                </div>

                <div class="row g-3">
                    @foreach (var arac in ViewBag.Favoriler)
                    {
                        <div class="col-md-4">
                            <div class="card h-100 border-0 shadow-sm hover-card rounded-4">
                                <div class="position-relative">
                                    <img src="@arac.Resim" class="card-img-top rounded-top-4" style="height:200px; object-fit:cover;">

                                    <div class="position-absolute top-0 end-0 m-2">
                                        <div class="form-check form-switch">
                                            <input class="form-check-input compare-check p-2 bg-white border-primary" type="checkbox"
                                                   style="width:40px; height:20px; cursor:pointer;"
                                                   value="@arac.Id"
                                                   data-marka="@arac.Marka @arac.Model"
                                                   data-fiyat="@arac.Fiyat"
                                                   data-yakit="@arac.Yakit"
                                                   data-vites="@arac.Vites"
                                                   data-koltuk="@arac.Koltuk"
                                                   data-resim="@arac.Resim"
                                                   onchange="checkStatus()">
                                        </div>
                                    </div>
                                </div>
                                <div class="card-body">
                                    <h5 class="fw-bold">@arac.Marka @arac.Model</h5>
                                    <p class="text-primary fw-bold fs-5 mb-0">@arac.Fiyat ₺ <small class="text-muted fs-6">/gün</small></p>
                                    <div class="d-flex justify-content-between mt-3 text-muted small">
                                        <span><i class="fas fa-gas-pump"></i> @arac.Yakit</span>
                                        <span><i class="fas fa-cogs"></i> @arac.Vites</span>
                                        <span><i class="fas fa-users"></i> @arac.Koltuk Kişi</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="tab-pane fade" id="tab-gecmis">
                <h5 class="fw-bold mb-3 text-dark">Son Baktıklarınız</h5>
                <div class="row g-3">
                    @foreach (var item in ViewBag.Gecmis)
                    {
                        <div class="col-md-3">
                            <div class="card border-0 shadow-sm rounded-4 opacity-75">
                                <img src="@item.Resim" class="card-img-top rounded-top-4" style="height:150px; object-fit:cover;">
                                <div class="card-body text-center">
                                    <h6 class="fw-bold">@item.Marka @item.Model</h6>
                                    <a href="#" class="btn btn-sm btn-outline-primary rounded-pill w-100 mt-2">İncele</a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="compareModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content rounded-4 border-0">
                <div class="modal-header bg-dark text-white rounded-top-4">
                    <h5 class="modal-title"><i class="fas fa-balance-scale me-2"></i>Karşılaştırma</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-0">
                    <table class="table table-bordered text-center align-middle mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th class="w-25">Özellik</th>
                                <th class="w-35 text-primary" id="cTitle1">Araç 1</th>
                                <th class="w-35 text-danger" id="cTitle2">Araç 2</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>Görsel</td>
                                <td><img src="" id="cImg1" class="img-fluid rounded" style="max-height:100px;"></td>
                                <td><img src="" id="cImg2" class="img-fluid rounded" style="max-height:100px;"></td>
                            </tr>
                            <tr><td class="fw-bold">Fiyat</td><td id="cPrice1" class="fw-bold"></td><td id="cPrice2" class="fw-bold"></td></tr>
                            <tr><td>Yakıt</td><td id="cFuel1"></td><td id="cFuel2"></td></tr>
                            <tr><td>Vites</td><td id="cGear1"></td><td id="cGear2"></td></tr>
                            <tr><td>Kapasite</td><td id="cSeat1"></td><td id="cSeat2"></td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="filterModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content rounded-4 border-0">
                <div class="modal-header">
                    <h5 class="modal-title fw-bold">Araç Filtrele</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form>
                        <label class="fw-bold mb-2">Kişi Sayısı</label>
                        <div class="d-flex gap-2 mb-3">
                            <input type="radio" class="btn-check" name="koltuk" id="k2" autocomplete="off">
                            <label class="btn btn-outline-secondary flex-fill" for="k2">2 Kişilik</label>

                            <input type="radio" class="btn-check" name="koltuk" id="k4" autocomplete="off" checked>
                            <label class="btn btn-outline-secondary flex-fill" for="k4">4-5 Kişilik</label>

                            <input type="radio" class="btn-check" name="koltuk" id="k7" autocomplete="off">
                            <label class="btn btn-outline-secondary flex-fill" for="k7">7+ Minivan</label>
                        </div>

                        <label class="fw-bold mb-2">Vites Tipi</label>
                        <div class="d-flex gap-2 mb-3">
                            <input type="checkbox" class="btn-check" id="v1">
                            <label class="btn btn-outline-secondary flex-fill" for="v1">Manuel</label>
                            <input type="checkbox" class="btn-check" id="v2" checked>
                            <label class="btn btn-outline-secondary flex-fill" for="v2">Otomatik</label>
                        </div>

                        <button type="button" class="btn btn-primary w-100 rounded-pill fw-bold">Sonuçları Göster</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // 1. Kıyaslama Kutularını Kontrol Etme
        function checkStatus() {
            var checkedBoxes = document.querySelectorAll('.compare-check:checked');
            var count = checkedBoxes.length;
            var btn = document.getElementById('btnCompare');
            var allBoxes = document.querySelectorAll('.compare-check');

            document.getElementById('countSpan').innerText = count;

            if (count === 2) {
                btn.disabled = false;
                btn.classList.remove('btn-secondary');
                btn.classList.add('btn-success');
                allBoxes.forEach(box => { if (!box.checked) box.disabled = true; });
            } else {
                btn.disabled = true;
                btn.classList.add('btn-secondary');
                btn.classList.remove('btn-success');
                allBoxes.forEach(box => box.disabled = false);
            }
        }

        // 2. Kıyaslama Modalını Açma
        function compareSelected() {
            var items = document.querySelectorAll('.compare-check:checked');
            if (items.length !== 2) return;

            // Araç 1
            document.getElementById('cTitle1').innerText = items[0].getAttribute('data-marka');
            document.getElementById('cPrice1').innerText = items[0].getAttribute('data-fiyat') + ' ₺';
            document.getElementById('cFuel1').innerText = items[0].getAttribute('data-yakit');
            document.getElementById('cGear1').innerText = items[0].getAttribute('data-vites');
            document.getElementById('cSeat1').innerText = items[0].getAttribute('data-koltuk') + ' Kişilik';
            document.getElementById('cImg1').src = items[0].getAttribute('data-resim');

            // Araç 2
            document.getElementById('cTitle2').innerText = items[1].getAttribute('data-marka');
            document.getElementById('cPrice2').innerText = items[1].getAttribute('data-fiyat') + ' ₺';
            document.getElementById('cFuel2').innerText = items[1].getAttribute('data-yakit');
            document.getElementById('cGear2').innerText = items[1].getAttribute('data-vites');
            document.getElementById('cSeat2').innerText = items[1].getAttribute('data-koltuk') + ' Kişilik';
            document.getElementById('cImg2').src = items[1].getAttribute('data-resim');

            var modal = new bootstrap.Modal(document.getElementById('compareModal'));
            modal.show();
        }
    </script>
</body>
</html>