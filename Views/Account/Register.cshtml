@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EasyRent - Kayıt Ol</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css">
    <link rel="stylesheet" href="~/css/landing.css?v=final_reg">

    <style>
        body {
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            font-family: 'Segoe UI', sans-serif;
            padding: 0 !important;
        }

        .login-card {
            width: 100%;
            max-width: 450px;
            padding: 30px;
            border-radius: 20px;
            background: var(--widget-bg);
            border: 1px solid var(--widget-border);
            box-shadow: 0 25px 50px rgba(0,0,0,0.3);
            backdrop-filter: blur(15px);
            animation: fadeInUp 0.8s ease-out;
        }

        .form-control, .input-group-text {
            background-color: var(--input-bg) !important;
            border-color: var(--input-border) !important;
            color: var(--text-main) !important;
        }
    </style>
</head>
<body data-theme="light">

    <div class="bg-slideshow"><div class="bg-slide"></div><div class="bg-slide"></div><div class="bg-slide"></div></div>
    <div class="bg-overlay"></div>

    <div class="login-card">
        <div class="text-center mb-4">
            <i class="fas fa-user-plus fa-3x text-primary mb-3"></i>
            <h3 class="fw-bold" style="color:var(--text-main)" data-lang="link_register">Hesap Oluştur</h3>
            <p class="small" style="color:var(--text-muted)" data-lang="reg_desc">Hızlıca kayıt olun ve araç kiralamaya başlayın.</p>
        </div>

        <form action="/Account/Register" method="post">
            <div class="row g-2 mb-3">
                <div class="col-6">
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-user"></i></span>
                        <input type="text" name="FirstName" class="form-control" data-lang-placeholder="lbl_name" placeholder="Ad" required>
                    </div>
                </div>
                <div class="col-6">
                    <div class="input-group">
                        <input type="text" name="LastName" class="form-control" data-lang-placeholder="lbl_surname" placeholder="Soyad" required>
                    </div>
                </div>
            </div>

            <div class="mb-3">
                <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-envelope"></i></span>
                    <input type="email" name="Email" class="form-control" data-lang-placeholder="lbl_email" placeholder="E-Posta" required>
                </div>
            </div>

            <div class="mb-3">
                <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-lock"></i></span>
                    <input type="password" name="Password" class="form-control" data-lang-placeholder="lbl_pass" placeholder="Şifre" required>
                </div>
            </div>

            <button type="submit" class="btn btn-primary w-100 btn-lg shadow-sm fw-bold mb-3 rounded-pill" data-lang="link_register">
                KAYIT OL
            </button>

            <div class="text-center mt-3">
                <p class="small" style="color:var(--text-muted)">
                    <span data-lang="reg_already">Zaten hesabınız var mı?</span>
                    <a href="/Account/CustomerLogin" class="text-primary fw-bold text-decoration-none" data-lang="btn_login_main">Giriş Yap</a>
                </p>
            </div>
        </form>
    </div>

    <script src="~/js/landing.js?v=final_reg"></script>
</body>
</html>