            <div class="text-center mb-5 text-white animate__animated animate__fadeInDown">
                <h1 class="display-4 fw-bold hero-title" data-lang="hero_title">Güvenli ve Konforlu Yolculuk</h1>
                <p class="lead hero-desc" data-lang="hero_desc">Adana'nın en geniş araç filosu ve 7/24 hizmet garantisi.</p>
            </div>
            <div class="row justify-content-center animate__animated animate__fadeInUp">
                <div class="col-xl-12">
                    <div class="search-widget rounded-4 shadow-lg overflow-hidden">
                        <div class="widget-header d-flex border-bottom">
                            <button class="widget-tab active" onclick="switchTab('daily')" id="tab-daily"><i class="fas fa-calendar-day me-2"></i> <span data-lang="tab_daily">Günlük Kiralama</span></button>
                            <button class="widget-tab" onclick="switchTab('monthly')" id="tab-monthly"><i class="fas fa-calendar-alt me-2"></i> <span data-lang="tab_monthly">Aylık Kiralama</span></button>
                            <button class="widget-tab" onclick="switchTab('reservation')" id="tab-reservation"><i class="fas fa-search me-2"></i> <span data-lang="tab_res">Rezervasyon İşlemleri</span></button>
                        </div>
                        <div class="widget-body p-4">
                            <form id="rentalForm" onsubmit="searchCars(event)">
                                <div class="row g-2 align-items-end" id="mainRow">
                                    <div class="col-lg-3 transition-col" id="col-pickup">
                                        <label class="label-custom" data-lang="lbl_pickup">ALIŞ YERİ</label>
                                        <div class="input-group"><span class="input-group-text"><i class="fas fa-map-marker-alt text-primary"></i></span><select class="form-select fw-bold text-truncate" id="pickupLoc"><option disabled selected data-lang="opt_select">Seçiniz</option><optgroup label="Adana"><option value="ADA" data-lang="loc_ada">Havalimanı</option><option value="SEYHAN" data-lang="loc_seyhan">Seyhan Ofis</option></optgroup></select></div>
                                    </div>
                                    <div class="col-lg-0 d-none transition-col" id="col-dropoff">
                                        <label class="label-custom" data-lang="lbl_dropoff">İADE YERİ</label>
                                        <div class="input-group"><span class="input-group-text"><i class="fas fa-map-pin text-danger"></i></span><select class="form-select fw-bold text-truncate" id="dropoffLoc"><option value="ADA" data-lang="loc_ada">Havalimanı</option><option value="SEYHAN" data-lang="loc_seyhan">Seyhan Ofis</option></select></div>
                                    </div>
                                    <div class="col-lg-6" id="col-dates">
                                        <div class="row g-1">
                                            <div class="col-4"><label class="label-custom" data-lang="lbl_pdate">ALIŞ TARİHİ</label><input type="text" class="form-control fw-bold flatpickr-input" id="pickupDate" readonly data-lang-placeholder="ph_date" placeholder="Tarih"></div>
                                            <div class="col-2"><label class="label-custom" data-lang="lbl_time">SAAT</label><select class="form-select text-center fw-bold px-0" id="pickupTime"></select></div>
                                            <div class="col-4 daily-only"><label class="label-custom" data-lang="lbl_ddate">DÖNÜŞ TARİHİ</label><input type="text" class="form-control fw-bold flatpickr-input" id="dropoffDate" readonly data-lang-placeholder="ph_date" placeholder="Tarih"></div>
                                            <div class="col-2 daily-only"><label class="label-custom" data-lang="lbl_time">SAAT</label><select class="form-select text-center fw-bold px-0" id="dropoffTime"></select></div>
                                            <div class="col-6 monthly-only d-none"><label class="label-custom" data-lang="lbl_duration">SÜRE</label><select class="form-select fw-bold"><option value="1" data-lang="dur_1">1 Ay</option><option value="3" data-lang="dur_3">3 Ay</option><option value="6" data-lang="dur_6">6 Ay</option></select></div>
                                        </div>
                                    </div>
                                    <div class="col-lg-3 transition-col" id="col-btn"><button type="submit" class="btn btn-primary w-100 fw-bold h-100 shadow-sm text-uppercase"><span data-lang="btn_find">ARAÇ BUL</span> <i class="fas fa-chevron-right ms-2"></i></button></div>
                                </div>
                                <div class="mt-2"><div class="form-check d-inline-block"><input class="form-check-input cursor-pointer" type="checkbox" id="diffLocCheck" onchange="toggleDropoff()"><label class="form-check-label label-custom cursor-pointer" for="diffLocCheck" data-lang="chk_diff">Farklı yerde teslim etmek istiyorum</label></div></div>
                            </form>
                            <form id="resForm" class="d-none" onsubmit="checkReservation(event)"><div class="row g-3 align-items-end"><div class="col-md-4"><label class="label-custom" data-lang="lbl_pnr">PNR KODU</label><input type="text" class="form-control fw-bold text-uppercase" id="resCode" data-lang-placeholder="ph_pnr" placeholder="Örn: 123456"><div class="invalid-feedback" data-lang="err_pnr">Kod giriniz.</div></div><div class="col-md-4"><label class="label-custom" data-lang="lbl_surname">SOYİSİM</label><input type="text" class="form-control fw-bold text-uppercase" id="resSurname" data-lang-placeholder="ph_surname" placeholder="SOYİSİM"><div class="invalid-feedback" data-lang="err_surname">Soyisim giriniz.</div></div><div class="col-md-4 d-flex gap-2"><button class="btn btn-info text-white w-50 h-100 fw-bold" data-lang="btn_query">SORGULA</button><button class="btn btn-danger w-50 h-100 fw-bold" data-lang="btn_cancel">İPTAL</button></div></div></form>
                        </div>
                    </div>
                </div>
