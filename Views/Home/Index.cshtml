    <section id="about" class="py-5 bg-section">
        <div class="container py-4">
            <div class="row align-items-center">
                <div class="col-lg-6 mb-4 mb-lg-0"><div class="p-3 glass-card rounded-4 shadow-sm d-inline-block"><img src="https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&w=800&q=80" class="img-fluid rounded-3" alt="Ofis"></div></div>
                <div class="col-lg-6 ps-lg-5">
                    <h6 class="text-primary fw-bold text-uppercase ls-2" data-lang="about_sub">Kurumsal</h6>
                    <h2 class="fw-bold mb-4 display-6 section-title" data-lang="about_title">Güvenin Adresi</h2>
                    <p class="section-desc lead" data-lang="about_desc1">2010 yılında Adana'da kurulan şirketimiz, müşteri memnuniyeti ilkesiyle hizmet vermektedir.</p>
                    <p class="section-desc" data-lang="about_desc2">Geniş araç filomuz ve şeffaf fiyat politikamızla sektörde fark yaratıyoruz.</p>
                    <div class="row mt-4 g-3">
                        <div class="col-6"><div class="border p-3 rounded-3 text-center bg-card"><h3 class="fw-bold text-primary mb-0">2010</h3><small class="card-text" data-lang="about_stat1">Kuruluş</small></div></div>
                        <div class="col-6"><div class="border p-3 rounded-3 text-center bg-card"><h3 class="fw-bold text-primary mb-0">50K+</h3><small class="card-text" data-lang="about_stat2">Müşteri</small></div></div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section id="filo" class="py-5">
        <div class="container">
            <div class="text-center mb-5"><h2 class="fw-bold section-title" data-lang="fleet_title">Araç Filomuz</h2><p class="section-desc" data-lang="fleet_desc">İhtiyacınıza uygun aracı seçin.</p></div>
            <div class="row">
                <div class="col-lg-3 mb-4">
                    <div class="filter-sidebar p-4 rounded-4 border sticky-top" style="top:100px;">
                        <div class="d-flex justify-content-between align-items-center mb-3"><h6 class="fw-bold mb-0 section-title" data-lang="filter_title">Filtrele</h6><button class="btn btn-sm text-danger p-0 fw-bold" onclick="resetFilters()" data-lang="filter_clear">Temizle</button></div>
                        <div class="mb-3"><label class="label-custom" data-lang="filter_brand">MARKA</label><select class="form-select form-select-sm" id="filterBrand" onchange="applyFilters()"><option value="all" data-lang="opt_all">Tümü</option><option value="Renault">Renault</option><option value="Fiat">Fiat</option><option value="BMW">BMW</option><option value="Mercedes">Mercedes</option></select></div>
                        <div class="mb-3"><label class="label-custom" data-lang="filter_year">MODEL YILI</label><select class="form-select form-select-sm" id="filterYear" onchange="applyFilters()"><option value="2020">2020+</option><option value="2022">2022+</option><option value="2024">2024+</option></select></div>
                        <div class="mb-3"><label class="label-custom" data-lang="filter_color">RENK</label><select class="form-select form-select-sm" id="filterColor" onchange="applyFilters()"><option value="all" data-lang="opt_all">Tümü</option><option value="Beyaz" data-lang="clr_white">Beyaz</option><option value="Siyah" data-lang="clr_black">Siyah</option></select></div>
                        <div class="mb-3"><label class="label-custom" data-lang="filter_gear">VİTES</label><div class="d-flex gap-2"><input type="radio" class="btn-check" name="gear" id="gearAll" value="all" checked onchange="applyFilters()"><label class="btn btn-outline-secondary btn-sm flex-fill" for="gearAll" data-lang="opt_all">Tümü</label><input type="radio" class="btn-check" name="gear" id="gearAuto" value="auto" onchange="applyFilters()"><label class="btn btn-outline-secondary btn-sm flex-fill" for="gearAuto" data-lang="gear_auto">Oto</label><input type="radio" class="btn-check" name="gear" id="gearManual" value="manual" onchange="applyFilters()"><label class="btn btn-outline-secondary btn-sm flex-fill" for="gearManual" data-lang="gear_manual">Man</label></div></div>
                        <div class="mb-3"><label class="label-custom" data-lang="filter_fuel">YAKIT</label><select class="form-select form-select-sm" id="filterFuel" onchange="applyFilters()"><option value="all" data-lang="opt_all">Tümü</option><option value="gasoline" data-lang="fuel_gas">Benzin</option><option value="diesel" data-lang="fuel_dsl">Dizel</option><option value="hybrid" data-lang="fuel_hyb">Hibrit</option></select></div>
                        <div class="mb-2"><label class="label-custom" data-lang="filter_price">MAX FİYAT</label><input type="range" class="form-range" min="500" max="10000" step="100" id="filterPrice" oninput="document.getElementById('priceVal').innerText=this.value+' ₺'" onchange="applyFilters()"><div class="d-flex justify-content-between small fw-bold text-primary"><span>500 ₺</span><span id="priceVal">5000 ₺</span></div></div>
                    </div>
                </div>
                <div class="col-lg-9"><div class="row g-4" id="vehicleGrid"></div><div id="noResultMsg" class="text-center py-5 d-none"><i class="fas fa-search fa-3x text-muted mb-3"></i><h5 class="text-muted" data-lang="no_result">Araç bulunamadı.</h5></div></div>
            </div>
        </div>
    </section>

    <section id="faq" class="py-5 bg-section">
