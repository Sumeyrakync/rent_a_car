                        <div class="accordion-item bg-card border mb-3 rounded"><h2 class="accordion-header"><button class="accordion-button collapsed bg-card section-title" type="button" data-bs-toggle="collapse" data-bs-target="#faq1" data-lang="faq_q1">Yaş sınırı?</button></h2><div id="faq1" class="accordion-collapse collapse" data-bs-parent="#faqAccordion"><div class="accordion-body card-text" data-lang="faq_a1">En az 21 yaş.</div></div></div>
                        <div class="accordion-item bg-card border mb-3 rounded"><h2 class="accordion-header"><button class="accordion-button collapsed bg-card section-title" type="button" data-bs-toggle="collapse" data-bs-target="#faq2" data-lang="faq_q2">Depozito?</button></h2><div id="faq2" class="accordion-collapse collapse" data-bs-parent="#faqAccordion"><div class="accordion-body card-text" data-lang="faq_a2">Evet, provizyon alınır.</div></div></div>
                        <div class="accordion-item bg-card border mb-3 rounded"><h2 class="accordion-header"><button class="accordion-button collapsed bg-card section-title" type="button" data-bs-toggle="collapse" data-bs-target="#faq3" data-lang="faq_q3">KM Sınırı?</button></h2><div id="faq3" class="accordion-collapse collapse" data-bs-parent="#faqAccordion"><div class="accordion-body card-text" data-lang="faq_a3">Günlük 400km.</div></div></div>
                        <div id="moreFaq" class="d-none">
                            <div class="accordion-item bg-card border mb-3 rounded"><h2 class="accordion-header"><button class="accordion-button collapsed bg-card section-title" type="button" data-bs-toggle="collapse" data-bs-target="#faq4" data-lang="faq_q4">Ek sürücü?</button></h2><div id="faq4" class="accordion-collapse collapse" data-bs-parent="#faqAccordion"><div class="accordion-body card-text" data-lang="faq_a4">Evet eklenebilir.</div></div></div>
                            <div class="accordion-item bg-card border mb-3 rounded"><h2 class="accordion-header"><button class="accordion-button collapsed bg-card section-title" type="button" data-bs-toggle="collapse" data-bs-target="#faq5" data-lang="faq_q5">İptal?</button></h2><div id="faq5" class="accordion-collapse collapse" data-bs-parent="#faqAccordion"><div class="accordion-body card-text" data-lang="faq_a5">24 saat kala ücretsiz.</div></div></div>
                        </div>
                    </div>
                    <div class="text-center mt-3"><button class="btn btn-link text-decoration-none fw-bold" id="btnShowAllFaq" onclick="toggleFaq()" data-lang="btn_see_all">Tüm Soruları Gör <i class="fas fa-chevron-down"></i></button></div>
