                <div class="col-lg-10">
                    <div class="review-card p-4 rounded-4 border shadow-sm position-relative overflow-hidden" id="guideCard">
                        <div id="guideText" style="max-height:150px; overflow:hidden; transition:max-height 0.5s ease;">
                            <p class="card-text mb-3" data-lang="guide_p1">Doğru araç seçimi önemlidir.</p>
                            <h6 class="fw-bold text-primary mt-3" data-lang="guide_h1">1. Seçim</h6><p class="card-text mb-2" data-lang="guide_p2">Yolcu ve bagaja göre seçin.</p>
                            <h6 class="fw-bold text-primary mt-3" data-lang="guide_h2">2. Sigorta</h6><p class="card-text mb-2" data-lang="guide_p3">Tam kasko önerilir.</p>
                            <h6 class="fw-bold text-primary mt-3" data-lang="guide_h3">3. Teslim</h6><p class="card-text mb-0" data-lang="guide_p4">Aracı kontrol ederek teslim alın.</p>
                            <h6 class="fw-bold text-primary mt-3" data-lang="guide_h4">4. İade</h6><p class="card-text mb-0" data-lang="guide_p5">Gecikme durumunda haber verin.</p>
                        </div>
                        <div class="text-center mt-3 pt-3 border-top position-relative bg-card" style="z-index:5;"><button class="btn btn-outline-primary rounded-pill px-4" id="btnExpandGuide" onclick="toggleGuide()" data-lang="btn_read_more">Devamını Oku <i class="fas fa-chevron-down ms-1"></i></button></div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section id="features" class="py-5">
