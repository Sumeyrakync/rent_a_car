                <div class="col-md-4"><div class="feature-card p-4 rounded-4 border h-100 hover-effect"><div class="icon-wrapper mb-3 text-success"><i class="fas fa-car-side fa-3x"></i></div><h5 class="fw-bold mb-2" data-lang="feat_2_t">Geniş Filo</h5><p class="card-text small" data-lang="feat_2_d">Her ihtiyaca uygun.</p></div></div>
                <div class="col-md-4"><div class="feature-card p-4 rounded-4 border h-100 hover-effect"><div class="icon-wrapper mb-3 text-danger"><i class="fas fa-headset fa-3x"></i></div><h5 class="fw-bold mb-2" data-lang="feat_3_t">7/24 Destek</h5><p class="card-text small" data-lang="feat_3_d">Her an yanınızda.</p></div></div>
