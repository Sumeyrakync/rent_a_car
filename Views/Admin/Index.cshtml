@{
    ViewData["Title"] = "Genel Bakış";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="d-flex flex-wrap gap-3 mb-4">
    <a asp-action="Index" class="btn btn-primary shadow-sm px-4 py-2 fw-bold">
        <i class="fas fa-home me-2"></i> Özet
    </a>
    <a asp-action="CarList" class="btn btn-dark border-secondary shadow-sm px-4 py-2 fw-bold">
        <i class="fas fa-car me-2"></i> Araç Listesi
    </a>
    <a asp-action="Rentals" class="btn btn-dark border-secondary shadow-sm px-4 py-2 fw-bold">
        <i class="fas fa-history me-2"></i> Kirada & Geçmiş
    </a>
    <button class="btn btn-dark border-secondary shadow-sm px-4 py-2 fw-bold disabled">
        <i class="fas fa-tools me-2"></i> Arızalı Araçlar
    </button>
</div>

<div class="row g-4 mb-5">
    <div class="col-md-3">
        <div class="card h-100 shadow-lg border-0" style="background-color: #0d6efd; color:white;">
            <div class="card-body d-flex align-items-center justify-content-between">
                <div>
                    <h6 class="fw-bold mb-1 opacity-75">TOPLAM ARAÇ</h6>
                    <h2 class="fw-bold mb-0 display-5">@ViewBag.TotalCars</h2>
                </div>
                <i class="fas fa-car fa-3x opacity-50"></i>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card h-100 shadow-lg border-0" style="background-color: #198754; color:white;">
            <div class="card-body d-flex align-items-center justify-content-between">
                <div>
                    <h6 class="fw-bold mb-1 opacity-75">MÜSAİT</h6>
                    @{
                        int total = (int)(ViewBag.TotalCars ?? 0);
                        int rented = (int)(ViewBag.RentedCars ?? 0);
                        int available = total - rented;
                    }
                    <h2 class="fw-bold mb-0 display-5">@available</h2>
                </div>
                <i class="fas fa-check-circle fa-3x opacity-50"></i>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card h-100 shadow-lg border-0" style="background-color: #ffc107; color:black;">
            <div class="card-body d-flex align-items-center justify-content-between">
                <div>
                    <h6 class="fw-bold mb-1 opacity-75">KİRADA</h6>
                    <h2 class="fw-bold mb-0 display-5">@ViewBag.RentedCars</h2>
                </div>
                <i class="fas fa-clock fa-3x opacity-50"></i>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card h-100 shadow-lg border-0" style="background-color: #dc3545; color:white;">
            <div class="card-body d-flex align-items-center justify-content-between">
                <div>
                    <h6 class="fw-bold mb-1 opacity-75">BAKIMDA</h6>
                    <h2 class="fw-bold mb-0 display-5">0</h2>
                </div>
                <i class="fas fa-exclamation-triangle fa-3x opacity-50"></i>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-4 mb-4">
        <div class="card bg-dark text-white border-secondary shadow h-100">
            <div class="card-header bg-transparent border-secondary fw-bold">
                <i class="fas fa-wallet text-success me-2"></i> Kasa Durumu
            </div>
            <div class="card-body text-center d-flex flex-column justify-content-center">
                <h5 class="text-white-50">Toplam Ciro</h5>
                <h1 class="display-4 fw-bold text-success">0 ₺</h1>
                <p class="small text-muted mt-2">Sadece tamamlanan kiralamalar dahildir.</p>
            </div>
        </div>
    </div>

    <div class="col-md-8 mb-4">
        <div class="card bg-dark text-white border-secondary shadow h-100">
            <div class="card-header bg-transparent border-secondary fw-bold d-flex justify-content-between align-items-center">
                <span><i class="fas fa-history text-primary me-2"></i> Son Hareketler</span>
                <span class="badge bg-secondary">Son İşlemler</span>
            </div>
            <div class="card-body p-0">
                <table class="table table-dark table-hover mb-0 align-middle">
                    <tbody>
                        <tr>
                            <td class="p-3"><span class="badge bg-primary">Kiralama</span></td>
                            <td>
                                <div class="fw-bold">Kiralama Yapıldı</div>
                                <small class="text-muted">BMW 5.20i -> Ahmet Yılmaz</small>
                            </td>
                            <td class="text-end text-muted small">Bugün</td>
                        </tr>
                        <tr>
                            <td class="p-3"><span class="badge bg-success">Ekleme</span></td>
                            <td>
                                <div class="fw-bold">Araç Eklendi</div>
                                <small class="text-muted">Peugeot 3008 (34 ABC 123)</small>
                            </td>
                            <td class="text-end text-muted small">Dün</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>