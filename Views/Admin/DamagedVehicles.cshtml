@model IEnumerable<rent_a_car.Models.Car>
@{
    ViewData["Title"] = "Arızalı Araçlar";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="text-white"><i class="fas fa-tools text-danger me-2"></i>Bakımdaki Araçlar</h4>
    <a asp-action="CarList" class="btn btn-outline-light btn-sm">Listeye Dön</a>
</div>

<div class="table-responsive">
    <table class="table admin-table table-hover align-middle">
        <thead>
            <tr>
                <th>Araç</th>
                <th>Plaka</th>
                <th>Durum</th>
                <th>İşlem</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td><span class="text-white fw-bold">@item.Brand @item.Model</span></td>
                    <td class="text-muted">@item.Plate</td>
                    <td><span class="badge bg-danger animate__animated animate__pulse animate__infinite">SERVİSTE</span></td>
                    <td>
                        <a href="/Admin/RepairVehicle/@item.Id" class="btn btn-success btn-sm fw-bold" onclick="return confirm('Araç tamir edildi ve kiralamaya hazır mı?');">
                            <i class="fas fa-wrench me-1"></i>Tamir Edildi (Aç)
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (!Model.Any())
{
    <div class="alert alert-success border-0 text-center opacity-75">
        <i class="fas fa-check-circle fa-2x mb-2"></i><br>
        Şu an arızalı veya bakımda olan araç yok. Her şey yolunda!
    </div>
}